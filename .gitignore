# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production

# secrets / one-off credential files
.github-token
*.pem
*.key

# vercel
.vercel

# temporary / backup files — never commit
*.bak
*.bak.*
*.patch
*.removed

# deploy scripts with potential creds
# Ignore the creds-carrying deploy shell scripts, but keep checked-in
# project tooling (e.g. scripts/convert-images-to-webp.ts) visible.
/scripts/*.sh
/scripts/deploy-*

# claude code worktrees / metadata
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
/public/uploads
.env*.local
