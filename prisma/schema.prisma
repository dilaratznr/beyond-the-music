generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum ArtistType {
  SOLO
  GROUP
  COMPOSER
}

enum ArchitectType {
  PRODUCER
  STUDIO
  MANAGER
  ARRANGER
  RECORD_LABEL
}

enum ArticleCategory {
  GENRE
  CULTURAL_IMPACT
  SUBCULTURE
  CURATED_MOVEMENT
  THEORY
  LISTENING_PATH
  AI_MUSIC
  DEEP_CUT
  FASHION
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  // canPublish yetkisi olmayan admin/editor "Yayınla" veya "Zamanla"
  // istediğinde makale doğrudan yayınlanmaz — PENDING_REVIEW'a düşer
  // ve ContentReview kuyruğunda Super Admin onayı bekler.
  PENDING_REVIEW
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Artist / Album / Architect / Genre / ListeningPath için yayın durumu.
/// Article'ın `ArticleStatus`'u ile aynı mantık — canPublish yetkisi
/// olmayan kullanıcıların create/edit'leri PENDING_REVIEW'a düşer,
/// ContentReview kuyruğunda Super Admin onayı bekler.
///
/// Var olan tüm kayıtlar migration'da default PUBLISHED alır — eski
/// içerik onaya girmez, sadece yeni akışa dahil yeni işlemler.
enum EntityStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum ListeningPathType {
  EMOTION
  ERA
  CITY
  CONTRAST
  INTRO
  DEEP
}

enum MediaType {
  IMAGE
  VIDEO
  EMBED
}

model User {
  id          String           @id @default(cuid())
  /// Login için birincil tanımlayıcı. Format: `^[a-z0-9_-]{3,30}$`
  /// (lowercase + rakam + `_` + `-`). Zorunlu, unique. Email opsiyonel
  /// olduğu için davet linkleri ve login bu alana bağlı.
  username    String           @unique
  /// İsteğe bağlı — SMTP yapılandırılmışsa davet/notification için kullanılır,
  /// ayrıca login formunda alternatif tanımlayıcı (kullanıcı adı veya email).
  email       String?          @unique
  /// Bcrypt hash. Davet akışında Super Admin kullanıcı oluştururken
  /// şifre vermiyor — yerine rastgele bir placeholder hash kaydediyoruz
  /// ve `mustSetPassword=true` ile login'i bloke ediyoruz. Kullanıcı
  /// davet linkinden kendi şifresini belirliyor.
  password    String
  name        String
  role        Role             @default(EDITOR)
  avatar      String?
  isActive    Boolean          @default(true)
  /// true ise NextAuth authorize() login'e izin vermez. Davet kabul
  /// edilince false'a çekilir.
  mustSetPassword Boolean      @default(false) @map("must_set_password")
  /// 2FA (TOTP) secret — AES-256-GCM ile şifrelenmiş base32 string.
  /// Format: `iv:ciphertext:authTag` (hex). Encryption key NEXTAUTH_SECRET'tan
  /// türetiliyor (HKDF). twoFactorEnabledAt set olmamışsa setup yarım kalmış
  /// (kullanıcı QR taradı ama hiç doğrulamadı).
  twoFactorSecret    String?    @map("two_factor_secret")
  twoFactorEnabledAt DateTime?  @map("two_factor_enabled_at")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  articles    Article[]
  permissions UserPermission[]
  backupCodes BackupCode[]
  // Onay kuyruğu ilişkileri — bir user hem kendi gönderdiklerini
  // ("submittedReviews"), hem de Super Admin'se karar verdiklerini
  // ("reviewedReviews") görür. İkisi ayrı relation name ile.
  submittedReviews ContentReview[] @relation("ReviewSubmitter")
  reviewedReviews  ContentReview[] @relation("ReviewReviewer")
  // Davet akışı ilişkileri
  invitations      UserInvitation[] @relation("InvitationTarget")
  invitationsSent  UserInvitation[] @relation("InvitationSender")
  // Audit log: bu kullanıcının yaptığı işlemler. Kullanıcı silinince
  // kayıt korunsun (forensic) — actorId null'a düşer, log korunur.
  auditLogs        AuditLog[]       @relation("AuditActor")
}

/// Tek kullanımlık 2FA recovery kodları — kullanıcı telefonunu kaybedince
/// TOTP yerine bunlardan birini girer. Her kod sadece bir kez kullanılır.
///
/// Tasarım:
///   - Raw kod ASLA DB'de tutulmaz, sadece SHA-256 hash. Kullanıcıya bir
///     kez gösterilir (setup tamamlanırken / regenerate'te).
///   - Kullanıldığında kayıt SİLİNMEZ — `usedAt` set edilir → audit
///     amaçlı geçmiş tutulur.
///   - Yeni set generate edildiğinde tüm eski kodlar silinir (atomik).
///
/// 10 kod = endüstri standardı (GitHub, Google). Telefon kaybı +
/// bilgisayar kaybı gibi peş peşe sorunlara karşı yumuşak rezerv.
model BackupCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256(raw_code). Raw 8 karakter base32 (`A1B2-C3D4` formatında
  /// gösterilir, hash öncesi tire'lar strip'lenir).
  codeHash  String    @unique @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
}

/// Super Admin tarafından yeni hesap oluşturulduğunda üretilen davet
/// token'ı. PasswordResetToken ile aynı pattern: tokenHash saklanır,
/// raw token asla DB'de tutulmaz, expires + usedAt ile tek seferlik.
/// Aynı kullanıcıya birden fazla davet gönderilebilir (resend) — her
/// yeni davet öncekilerini "usedAt=now" ile geçersiz kılar.
model UserInvitation {
  id            String   @id @default(cuid())
  tokenHash     String   @unique @map("token_hash")
  userId        String   @map("user_id")
  user          User     @relation("InvitationTarget", fields: [userId], references: [id], onDelete: Cascade)
  invitedById   String   @map("invited_by_id")
  invitedBy     User     @relation("InvitationSender", fields: [invitedById], references: [id])
  expiresAt     DateTime @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   String   // GENRE, ARTIST, ALBUM, ARCHITECT, ARTICLE, LISTENING_PATH, MEDIA, THEORY, AI_MUSIC
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  canPublish Boolean @default(false)

  @@unique([userId, section])
}

model Genre {
  id             String    @id @default(cuid())
  slug           String    @unique
  nameTr         String    @map("name_tr")
  nameEn         String    @map("name_en")
  descriptionTr  String?   @map("description_tr") @db.Text
  descriptionEn  String?   @map("description_en") @db.Text
  image          String?
  parentId       String?
  parent         Genre?    @relation("GenreHierarchy", fields: [parentId], references: [id])
  children       Genre[]   @relation("GenreHierarchy")
  order          Int       @default(0)
  status         EntityStatus @default(PUBLISHED)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  artists        ArtistGenre[]
  articles       Article[] @relation("GenreArticles")

  @@index([status])
}

model Artist {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  type        ArtistType
  bioTr       String?      @map("bio_tr") @db.Text
  bioEn       String?      @map("bio_en") @db.Text
  image       String?
  birthDate   DateTime?
  deathDate   DateTime?
  status      EntityStatus @default(PUBLISHED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  genres      ArtistGenre[]
  albums      Album[]
  architects  ArchitectArtist[]
  articles    Article[]    @relation("ArtistArticles")
  listeningPathItems ListeningPathItem[] @relation("ArtistPathItems")

  @@index([status])
}

model ArtistGenre {
  artistId String
  genreId  String
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre    Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([artistId, genreId])
}

model Album {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  artistId       String
  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  releaseDate    DateTime?
  coverImage     String?
  descriptionTr  String?   @map("description_tr") @db.Text
  descriptionEn  String?   @map("description_en") @db.Text
  featuredOrder  Int?      @map("featured_order")
  status         EntityStatus @default(PUBLISHED)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  songs          Song[]
  listeningPathItems ListeningPathItem[] @relation("AlbumPathItems")

  @@index([featuredOrder])
  @@index([status])
}

model Song {
  id          String  @id @default(cuid())
  title       String
  albumId     String
  album       Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  trackNumber Int?
  duration    String?
  isDeepCut   Boolean @default(false)
  spotifyUrl  String?
  youtubeUrl  String?
  listeningPathItems ListeningPathItem[] @relation("SongPathItems")
}

model Architect {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  type      ArchitectType
  bioTr     String?        @map("bio_tr") @db.Text
  bioEn     String?        @map("bio_en") @db.Text
  image     String?
  status    EntityStatus   @default(PUBLISHED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  artists   ArchitectArtist[]

  @@index([status])
}

model ArchitectArtist {
  architectId String
  artistId    String
  role        String?
  architect   Architect @relation(fields: [architectId], references: [id], onDelete: Cascade)
  artist      Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([architectId, artistId])
}

model Article {
  id             String          @id @default(cuid())
  slug           String          @unique
  titleTr        String          @map("title_tr")
  titleEn        String          @map("title_en")
  contentTr      String?         @map("content_tr") @db.Text
  contentEn      String?         @map("content_en") @db.Text
  category       ArticleCategory
  featuredImage  String?
  authorId       String
  author         User            @relation(fields: [authorId], references: [id])
  status         ArticleStatus   @default(DRAFT)
  publishedAt    DateTime?
  featuredOrder  Int?            @map("featured_order")
  relatedGenreId  String?
  relatedGenre    Genre?         @relation("GenreArticles", fields: [relatedGenreId], references: [id])
  relatedArtistId String?
  relatedArtist   Artist?        @relation("ArtistArticles", fields: [relatedArtistId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([featuredOrder])
}

model ListeningPath {
  id             String            @id @default(cuid())
  slug           String            @unique
  titleTr        String            @map("title_tr")
  titleEn        String            @map("title_en")
  descriptionTr  String?           @map("description_tr") @db.Text
  descriptionEn  String?           @map("description_en") @db.Text
  type           ListeningPathType
  image          String?
  status         EntityStatus      @default(PUBLISHED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          ListeningPathItem[]

  @@index([status])
}

model ListeningPathItem {
  id        String        @id @default(cuid())
  pathId    String
  path      ListeningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  songId    String?
  song      Song?         @relation("SongPathItems", fields: [songId], references: [id])
  albumId   String?
  album     Album?        @relation("AlbumPathItems", fields: [albumId], references: [id])
  artistId  String?
  artist    Artist?       @relation("ArtistPathItems", fields: [artistId], references: [id])
  order     Int           @default(0)
  noteTr    String?       @map("note_tr") @db.Text
  noteEn    String?       @map("note_en") @db.Text
}

model MediaItem {
  id         String    @id @default(cuid())
  url        String
  type       MediaType
  captionTr  String?   @map("caption_tr")
  captionEn  String?   @map("caption_en")
  entityType String
  entityId   String
  createdAt  DateTime  @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

/// Merkezi onay kuyruğu. İçerik modellerinin kendisine dokunmadan
/// "Super Admin onayından geçiyor" durumunu tutuyor:
///   - section + entityId: hangi modelin hangi kaydıyla ilgili
///     (başlangıçta sadece ARTICLE kullanılıyor, ilerideki fazlarda
///     ARTIST/ALBUM/... genişleyecek)
///   - changeType: CREATE ya da EDIT — yayındaki bir makalede düzenleme
///     mi, yoksa yeni makalenin yayın talebi mi
///   - entityTitle: admin listede göstermek için dondurulmuş başlık
///     (makale silinirse bile kuyruk okunabilir kalsın diye)
///   - submittedBy → reviewedBy: kim gönderdi → Super Admin kim karar verdi
///   - reviewNote: reddederken opsiyonel açıklama
model ContentReview {
  id            String       @id @default(cuid())
  section       String       // 'ARTICLE' | 'ARTIST' | 'ALBUM' | ... (Faz 2'de genişleyecek)
  entityId      String
  entityTitle   String
  changeType    String       // 'CREATE' | 'EDIT'
  status        ReviewStatus @default(PENDING)
  reviewNote    String?      @db.Text

  submittedById String
  submittedBy   User         @relation("ReviewSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  submittedAt   DateTime     @default(now())

  reviewedById  String?
  reviewedBy    User?        @relation("ReviewReviewer", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?

  @@index([status, submittedAt])
  @@index([section, entityId])
}

model HeroVideo {
  id       String  @id @default(cuid())
  url      String
  duration Int     @default(10) // seconds to show this video
  order    Int     @default(0)
  isActive Boolean @default(true)
  title    String?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  // SHA-256 hex digest of the token. We never store the raw token.
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
}

/// Güvenlik denetim kaydı (audit log).
///
/// Amaç: breach response, forensic, ve normal şartlarda "kim ne zaman ne
/// yaptı?" sorusuna anlık cevap vermek. Admin paneline kim girip çıktı,
/// kim hangi içeriği sildi, kim kimin yetkisini değiştirdi — bunlar
/// kalıcı olarak kayıtlı kalır.
///
/// Saldırı sonrası en kritik soru: "ne zaman başladı, hangi hesap
/// kompromize oldu?". Audit log olmazsa bu soruyu cevaplamak imkansız.
///
/// PII minimize: ipHash sha256 ile maskelenmiş; raw IP yazmıyoruz ki
/// breach durumunda bu tablo da exfiltrate edilse user IP'leri sızmasın.
/// userAgent ham — fingerprint için yeterli, kişi tanımlamak için değil.
///
/// Retention: cleanup-tokens cron'unda 90 gün üstü kayıtlar silinebilir
/// (ileride). Şimdilik manuel.
model AuditLog {
  id        String   @id @default(cuid())
  /// Olay türü — string enum yerine string tutuyoruz ki yeni event tipleri
  /// schema migration gerektirmesin. Standart isimler:
  ///   LOGIN_SUCCESS, LOGIN_FAILURE, LOGOUT,
  ///   USER_CREATED, USER_DELETED, USER_ROLE_CHANGED, PERMISSIONS_CHANGED,
  ///   PASSWORD_CHANGED, PASSWORD_RESET_REQUESTED,
  ///   ARTICLE_DELETED, ARTIST_DELETED, ALBUM_DELETED, …
  event     String
  /// İşlemi yapan kullanıcı (login fail için null — henüz auth yok).
  actorId   String?  @map("actor_id")
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  /// İşlem hangi kullanıcıyı/objeyi etkiledi (login için actor=target).
  targetId  String?  @map("target_id")
  /// Etkilenen objenin tipi: USER / ARTICLE / ALBUM / ARTIST / GENRE / …
  targetType String? @map("target_type")
  /// SHA-256(IP) — gerçek IP'yi yazmıyoruz; aynı IP'den gelen
  /// olaylar aynı hash'e sahip olur, breach exfiltrate'inde bile
  /// reverse mümkün değil (32-bit space + salt yok ama OK).
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  /// Serbest metin — login fail için "wrong password", role change için
  /// "EDITOR → ADMIN" gibi insan-okur özet.
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event, createdAt])
  @@index([actorId])
  @@index([createdAt])
}
