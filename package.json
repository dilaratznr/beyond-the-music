{
  "name": "beyond-the-music",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npx tsx scripts/migrate-add-username.ts && prisma db push --accept-data-loss --skip-generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:setup": "npx prisma db push && npx tsx prisma/seed.ts",
    "analyze": "cross-env ANALYZE=true next build",
    "media:migrate": "tsx scripts/convert-images-to-webp.ts",
    "media:migrate:apply": "tsx scripts/convert-images-to-webp.ts --apply",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@studio-freight/lenis": "^1.0.42",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/extension-youtube": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.1",
    "dotenv": "^17.3.1",
    "gsap": "^3.14.2",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "otpauth": "^9.5.1",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.8",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.13.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "nodemailer": "^7.0.13",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
