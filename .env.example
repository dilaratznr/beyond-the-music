# ─────────────────────────────────────────────────────────────────────────────
# Beyond The Music — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, or paste these keys into
# your hosting provider's environment settings (Vercel → Project → Settings
# → Environment Variables) for production.
#
# Required values are marked (required). Everything else is optional.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (required) ──────────────────────────────────────────────────────
# Postgres connection string.
#   • Local dev:  postgresql://btm_user:btm_secret_2024@localhost:5432/beyond_the_music
#   • Production: paste the "Pooled connection" string from Neon / Supabase /
#                 Vercel Postgres.
DATABASE_URL="postgresql://btm_user:btm_secret_2024@localhost:5432/beyond_the_music"


# ── Auth (required) ──────────────────────────────────────────────────────────
# Canonical site URL used by NextAuth for sign-in callbacks.
#   • Local dev:  http://localhost:3000
#   • Production: https://yourdomain.com   (match your real domain exactly)
NEXTAUTH_URL="http://localhost:3000"

# Random 32+ character string. Generate with:
#   openssl rand -base64 32
# Never reuse dev secret in production.
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"


# ── App (required) ───────────────────────────────────────────────────────────
# Publicly exposed site URL (used in SEO / sitemap / open-graph tags).
# Should match NEXTAUTH_URL. Production'da gerçek domain olmalı yoksa
# robots.ts ve sitemap.ts hardcoded fallback URL'i kullanır.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Eski adı NEXT_PUBLIC_SITE_URL — robots.ts hâlâ bunu da okuyabilir.
# Aynı değeri tut, geriye dönük uyumluluk için.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ── AI translation (optional) ────────────────────────────────────────────────
# Google Gemini key used for TR ↔ EN auto-translate in admin forms.
# If empty, bilingual fields must be filled by hand.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=""


# ── Image storage — Cloudflare R2 / AWS S3 (optional, strongly recommended) ──
# Without these, uploads fall back to writing to /public/uploads on disk,
# which *does not persist* on Vercel / serverless hosting.
#
# Recommended: Cloudflare R2 (free up to 10 GB).
#   1. Create a bucket in dash.cloudflare.com → R2
#   2. "Manage R2 API Tokens" → Create API token with Object Read & Write
#   3. Enable public access for the bucket (Settings → Public access → "R2.dev")
#      or connect a custom domain for images.
#
# For Cloudflare R2, set AWS_S3_ENDPOINT_URL to:
#   https://<your-account-id>.r2.cloudflarestorage.com
# And AWS_S3_PUBLIC_DOMAIN to the R2.dev subdomain or your custom image domain.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_REGION="auto"
AWS_S3_ENDPOINT_URL=""
AWS_S3_PUBLIC_DOMAIN=""


# ── İletişim bilgileri ve sosyal linkler ─────────────────────────────────────
# ARTIK ENV'DEN GELMİYOR. Super Admin /admin/settings'ten yönetiyor:
# e-posta, telefon, adres, Instagram/YouTube/Spotify/X/TikTok URL'leri.
# Boş bırakılan alan public sitede hiç görünmez. Eski NEXT_PUBLIC_CONTACT_*
# / NEXT_PUBLIC_SOCIAL_* env'leri artık dikkate alınmıyor — kaldırılabilir.


# ── Email — devre dışı ───────────────────────────────────────────────────────
# Davet email'i kullanılmıyor — Super Admin yeni kullanıcı oluşturduğunda admin
# UI davet linkini doğrudan gösterir, manuel olarak Signal/WhatsApp/Slack ile
# iletilir. Domain doğrulama + 3rd-party servis bağımlılığı yok.
#
# İleride email göndermek istersen SMTP env'lerini ekle (Gmail App Password en
# kolayı, ya da Resend + doğrulanmış domain):
#   SMTP_HOST=smtp.gmail.com / smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=...
#   SMTP_PASSWORD=...
#   SMTP_FROM="Beyond The Music <noreply@yourdomain.com>"


# ── Cron secret (required for production) ───────────────────────────────────
# Vercel Cron, Authorization: Bearer <CRON_SECRET> header'ı ile günde bir
# /api/cron/cleanup-tokens çağırıyor. Set edilmediğinde endpoint kapalı kalır
# (fail-closed). Üret:
#   openssl rand -base64 32
CRON_SECRET=""


# ── Rate limiting — Upstash Redis (production'da önerilir) ───────────────────
# Vercel serverless'te her cold start in-memory rate-limit'i sıfırlar; multi-
# instance trafikte saldırgan farklı edge'lere isabet ederek limiti aşabilir.
# Upstash REST credentials'ı set edildiğinde otomatik olarak kullanılır.
# Set edilmezse in-memory fallback (dev için OK, production için risky).
#   1. https://upstash.com → Create Database → Type: Regional, Region: deploy
#      bölgenle aynı (genelde eu-central-1)
#   2. Database → REST API → URL ve Token'ı kopyala
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ── İlk Super Admin (sadece seed için, production'da boş bırakılabilir) ──────
# Boş DB'ye ilk Super Admin'i kurmak için seed.ts okur. Bu env'ler sadece
# `npm run db:seed` çalıştırıldığında bir kez kullanılır.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe-immediately-after-first-login"
